# ============================================================
# SmartDesk Backend — Environment Variables
# ============================================================
# HOW TO USE:
# 1. Copy this file: copy .env.example .env
# 2. Fill in your actual values below
# 3. NEVER commit .env to Git (it's already in .gitignore)
# ============================================================

# ----- OpenAI -----
# Your OpenAI API key — get it from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# The AI model to use for chat responses
OPENAI_MODEL=gpt-4o-mini

# The model used to convert text into embeddings (for search)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ----- Database -----
# Format: postgresql+asyncpg://username:password@host:port/database_name
# Example: postgresql+asyncpg://postgres:mypassword@localhost:5432/smartdesk
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/smartdesk

# Synchronous version (used by Alembic migrations)
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:your_password@localhost:5432/smartdesk

# ----- JWT Authentication -----
# A long random secret string used to sign JWT tokens
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_super_secret_jwt_key_change_this_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ----- App Settings -----
APP_NAME=SmartDesk
APP_VERSION=1.0.0
DEBUG=True

# The URL of your frontend (used for CORS — explained in Phase 3)
FRONTEND_URL=http://localhost:5173
